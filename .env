# Configuración del Sistema Hermes Orquestado
# Agency Swarm + OpenCode

# Modelo backend para orquestación (usar OpenRouter para modelos gratuitos)
# Registrate en https://openrouter.ai/keys (es gratis)
OPENROUTER_API_KEY=tu-api-key-aqui
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Proveedor de modelos: openrouter | openai | anthropic
MODEL_PROVIDER=openrouter

# O usa OpenAI si tenés
# OPENAI_API_KEY=tu-api-key-aqui

# O Anthropic
# ANTHROPIC_API_KEY=tu-api-key-aqui

# Langfuse para tracing (opcional, self-hosted o cloud)
# LANGFUSE_PUBLIC_KEY=tu-key
# LANGFUSE_SECRET_KEY=tu-key
# LANGFUSE_HOST=https://cloud.langfuse.com

# OpenCode (debe estar instalado en el sistema)
OPENCODE_CMD=opencode

# Working Memory
HERMES_STATE_DIR=/home/agust/hermes-orchestrator/workspace/.hermes-state

# Modo debug
DEBUG=false
