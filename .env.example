# Synto — Environment Variables
# Copy this file to .env and fill in your values.

# ── LLM Providers ──────────────────────────────────────────

# OpenCode Zen (free models: big-pickle, glm-4.7, kimi-k2.5, etc.)
# Get your key from https://opencode.ai/zen
OPENCODE_ZEN_API_KEY=

# OpenRouter (Minimax, Gemma, Qwen, etc.)
# Get your key from https://openrouter.ai/
OPENROUTER_API_KEY=

# OpenCode auth.json path (for OpenAI OAuth — gpt-5, o4-mini, etc.)
# Leave empty to use default paths (~/.local/share/opencode/auth.json)
OPENCODE_AUTH_PATH=

# ── Synto Paths ────────────────────────────────────────────

# Workspace directory (where Synto stores state)
SYNTO_WORKSPACE_DIR=

# Projects root (where per-project state lives)
SYNTO_PROJECTS_ROOT=

# Memory database path
SYNTO_MEMORY_DB=

# Agent registry path (usually AGENT-REGISTRY.yaml in repo root)
SYNTO_AGENT_REGISTRY=

# LLM config directory (providers.yaml + models.yaml)
SYNTO_CONFIG_DIR=

# Skill directories (colon-separated on Linux, semicolon on Windows)
SYNTO_SKILLS_DIRS=
